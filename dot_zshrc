##
# ⚠️ WARNING: Don't manually `source` your .zshrc file! This can have unexpected
# side effects.
# Instead, to apply changes, open a new terminal or restart your shell.
#

export XDG_CONFIG_HOME=~/.config

##
# Plugin manager: antidote (replaced znap). Plugin list is in ~/.zsh_plugins.txt.
# `antidote load` bundles + caches + sources it, recompiling when the list changes.
#
if [[ -r /opt/homebrew/opt/antidote/share/antidote/antidote.zsh ]]; then
  source /opt/homebrew/opt/antidote/share/antidote/antidote.zsh
else
  [[ -d ~/.antidote ]] || git clone --depth=1 https://github.com/mattmc3/antidote ~/.antidote
  source ~/.antidote/antidote.zsh
fi

LC_CTYPE=en_US.UTF-8
LC_ALL=en_US.UTF-8


eval "$(/opt/homebrew/bin/brew shellenv)"

eval "$(mise activate zsh)"


# Load all plugins from ~/.zsh_plugins.txt (prezto modules, completions, clitest;
# fzf-tab + zsh-autosuggestions are deferred to after compinit). Dropped the
# ohmyzsh asdf plugin — superseded by mise (activated above).
antidote load


# `znap prompt` makes your prompt visible in just 15-40ms!
#znap prompt sindresorhus/pure
# The same goes for any other kind of custom prompt:
#znap eval starship 'starship init zsh --print-full-init'
#znap prompt 
eval "$(starship init zsh)"

#znap prompt ohmyzsh/ohmyzsh themes/clean
#znap prompt agnoster/agnoster-zsh-theme


##
# Cache the output of slow commands with `znap eval`.
#

# NOTE: completion UX is fzf-tab + zsh-autosuggestions (see ~/.zsh_plugins.txt),
# replacing the old zsh-autocomplete whose live redraw overwrote the multi-line
# prompt. They're deferred to load after compinit; the default Tab widget is left
# alone so fzf-tab can hook it (no menu-complete bindings).

# TO enable color in man output using bat
export MANPAGER="sh -c 'col -bx | bat -l man -p'"

#fortune | cowsay | lolcat
autoload -Uz compinit && compinit

export CARAPACE_BRIDGES='zsh,fish,bash,inshellisense' # optional
zstyle ':completion:*' format $'\e[2;37mCompleting %d\e[m'
source <(carapace _carapace)

export _ZO_DATA_DIR="${HOME}/.local/share/zoxide"
eval "$(zoxide init --cmd cd zsh)"
source <(fzf --zsh)

# fzf-tab needs zsh's own menu disabled so it can take over the Tab menu.
# (fzf-tab itself is loaded via antidote, deferred until after compinit.)
zstyle ':completion:*' menu no

export FZF_DEFAULT_COMMAND="fd --hidden --strip-cwd-prefix --exclude .git "
export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
export FZF_ALT_C_COMMAND="fd --type=d --hidden --strip-cwd-prefix --exclude .git"

export FZF_DEFAULT_OPTS="--height 50% --layout=default --border --color=hl:#2dd4bf"

# Setup fzf previews
export FZF_CTRL_T_OPTS="--preview 'bat --color=always -n --line-range :500 {}'"
export FZF_ALT_C_OPTS="--preview 'eza --icons=always --tree --color=always {} | head -200'"

# fzf preview for tmux
export FZF_TMUX_OPTS=" -p90%,70% "

#region atouin - fuzzy search history

eval "$(atuin init zsh --disable-up-arrow)"

bindkey '^r' _atuin_search_widget

# depends on terminal mode
bindkey '^[[A' _atuin_search_widget
bindkey '^[OA' _atuin_search_widget


#endregion

#region autoloaded functions
fpath=(~/.local/autoloaded "${fpath[@]}")
autoload -Uz $fpath[1]/*(.:t)
#endregion

#region path definitions
export aliases_location="$HOME/.config/aliases" && source "$aliases_location"
export shell_functions_location="$HOME/.local/autoloaded"
export bin_functions_location="$HOME/.local/scripts"
export PATH=$bin_functions_location:$PATH

stty -ixon

source $XDG_CONFIG_HOME/aliases

alias zrcedit="vi $XDG_CONFIG_HOME/zsh/.zshrc"
alias zrcreload="source $XDG_CONFIG_HOME/zsh/.zshrc"

alias esp531="source ~/.tools/espidf/esp-idf-v531/export.sh"
alias helpers="source bin/helpers.sh"

export GOBIN=~/.go
#source "$HOME/.local/bin/env"

function upto ()
{
    if [ -z "$1" ]; then
        return
    fi
    local upto=$1
    cd "${PWD/\/$upto\/*//$upto}"
}

# I also have completion for this function, so that it gives me valid directory names and co
# mpletion when I hit tab:
function _upto()
{
    local d=${PWD//\//\ }
    local x=$(echo $d | tr ' ' ',')
    x=${x:1}
    local opts=("${(@s/,/)x}")
    compadd $opts
    # compadd kotlin python

}
compdef _upto upto

eval $(thefuck --alias)


_zoxide_zsh_tab_completion() {
    (( $+compstate )) && compstate[insert]=menu
    local keyword="${words:2}"
    local completions=(${(@f)"$(zoxide query -l "$keyword")"})


    if [[ ${#completions[@]} == 0 ]]; then
        _files -/
    else
        compadd -U -V z "${(@)completions}"
    fi
}

if [ "${+functions[compdef]}" -ne 0 ]; then
    compdef _zoxide_zsh_tab_completion z 2> /dev/null
fi

eval "$(direnv hook zsh)"

export PATH=$PATH:~/.local/scripts
export PATH=~/.local/bin:$PATH

# Modern-tool helper: `alts` cheat-sheet + intercept `top` (etc.) to offer the
# modern equivalents you have installed. See ~/.config/zsh/tool-alts.zsh.
source ~/.config/zsh/tool-alts.zsh
